{
  "headers": [
    {
      "source": "/(.*).apk",
      "headers": [
        {
          "key": "Content-Type",
          "value": "application/vnd.android.package-archive"
        },
        {
          "key": "Content-Disposition",
          "value": "attachment"
        }
      ]
    }
  ],
  "routes": [
    {
      "src": "/(.*).apk",
      "dest": "/$1.apk",
      "methods": ["GET"]
    }
  ]
}
